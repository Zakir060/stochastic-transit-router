# ------ YAML Diff ------
*.yaml diff=yaml
*.yml diff=yaml

# ------ Python Diff ------
*.py diff=python

# ------ Markdown Diff ------
*.md diff=markdown

# ------ XML Diff ------
*.xml diff=xml

