# ============================================================================
# MERGE STRATEGIES - CUSTOM HANDLING FOR CONFLICTS
# ============================================================================

# ------ Prefer ours/theirs for specific files ------
# Lock files should typically use ours (left) when merging
poetry.lock merge=ours
Pipfile.lock merge=ours

# ------ Union merge for documentation ------
# Multiple CHANGELOG entries can exist
CHANGELOG.md merge=union

