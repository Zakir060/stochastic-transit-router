    "title":  "Graph Edge",
    "type":  "object",
    "additionalProperties":  false,
    "properties":  {
                       "from_node":  {
                                         "type":  "string"
                                     },
                       "edge_type":  {
                                         "type":  "string"
                                     },
                       "edge_id":  {
                                       "type":  "string"
                                   },
                       "metadata":  {
                                        "type":  "object"
                                    },
                       "to_node":  {
