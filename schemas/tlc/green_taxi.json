    "properties":  {
                       "dropoff_datetime":  {
                                                "type":  "string"
                                            },
                       "PULocationID":  {
                                            "type":  "integer"
                                        },
                       "total_amount":  {
                                            "type":  "number"
                                        },
                       "trip_distance":  {
