# ============================================================================
# PROJECT-SPECIFIC DATA DIRECTORIES
# ============================================================================

# Raw data ingestion (never committed, too large)
data/raw/*
!data/raw/.gitkeep
!data/raw/README.md

# Processed data outputs (generated locally)
data/processed/*
!data/processed/.gitkeep
!data/processed/README.md

# Data cache (temporary, large files)
data/cache/*
!data/cache/.gitkeep

# Data exports and generated artifacts
data/exports/*
!data/exports/.gitkeep

# Provenance manifests for runs (generated during experiments)
data/manifests/*.jsonl
data/manifests/*.json
data/manifests/runs/*.jsonl
data/manifests/runs/*.json
!data/manifests/README.md
!data/manifests/.gitkeep

