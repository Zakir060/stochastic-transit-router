!.gitattributes
!.gitignore
!.github/
!.github/**
!.pre-commit-config.yaml
!.ruff.toml
!.mypy.ini
!.editorconfig
!README.md
!LICENSE
!CHANGELOG.md
!AUTHORS.md
!SECURITY.md
!CONTRIBUTING.md
!CITATION.cff

# Keep documentation files
!docs/**
!docs/**/*.md

# Keep source code
!src/**
!src/**/*.py

# Keep tests
!tests/**
!tests/**/*.py

# Keep scripts
!scripts/**
!scripts/**/*.py
!scripts/**/*.sh

# Keep data directory structure (but not large files)
!data/
!data/raw/
!data/processed/
!data/cache/
!data/exports/
!data/manifests/
!data/raw/.gitkeep
!data/raw/README.md
!data/processed/.gitkeep
!data/processed/README.md
!data/cache/.gitkeep
!data/manifests/.gitkeep
!data/manifests/README.md

# Keep benchmarks structure
!benchmarks/
!benchmarks/tests/
!benchmarks/results/
!benchmarks/reports/
!benchmarks/results/.gitkeep
!benchmarks/reports/report_template.md

# Keep experiments structure
!experiments/
!experiments/nyc/
!experiments/nyc/results/
!experiments/nyc/analysis/
!experiments/nyc/results/.gitkeep
!experiments/nyc/analysis/.gitkeep
!experiments/README.md
