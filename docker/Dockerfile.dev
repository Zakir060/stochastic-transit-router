# =============================================================================
# Stochastic Transit Router - Development Dockerfile
# Full Development Environment with Testing and Debugging Tools
#
# This Dockerfile builds a comprehensive development environment including:
# - All source code and test suites
# - Development dependencies (pytest, mypy, ruff, etc.)
# - Benchmarking tools and Jupyter notebooks
# - Volume mounting for live code editing
# - Interactive bash shell for exploration
#
# Build: docker build -f docker/Dockerfile.dev -t stochastic-transit-router:dev .
# Run:   docker-compose -f docker/docker-compose.dev.yml up
#
# Development Usage:
# - Interactive development: docker run -it -v $(pwd):/app stochastic-transit-router:dev
# - Run tests: docker run --rm stochastic-transit-router:dev pytest tests/
# - Type check: docker run --rm stochastic-transit-router:dev mypy src/
# - Format code: docker run --rm -v $(pwd):/app stochastic-transit-router:dev ruff format src/
#
# Documentation: https://docs.docker.com/develop/
# Best Practices: https://docs.docker.com/develop/dev-best-practices/
# =============================================================================

FROM python:3.12-slim

LABEL maintainer="Zakir Bayramov <zakirbayramov942@gmail.com>, Gustav Olaf Yunus Laitinen-Lundström Fredriksson-Imanov <olaf.laitinen@uni.lu>"
LABEL description="Stochastic Transit Router - Development Environment"
LABEL version="0.1.0"

# ============================================================================
# ENVIRONMENT - Development optimizations
# ============================================================================

# Python runtime behavior
ENV PYTHONDONTWRITEBYTECODE=1          # Don't generate .pyc files (cleaner development)
ENV PYTHONUNBUFFERED=1                 # Unbuffered output for real-time logging
ENV PYTHONHASHSEED=random              # Security: randomize hash functions
ENV PIP_NO_CACHE_DIR=1                 # Skip pip cache in container

# Development settings
ENV APP_ENV=development                # Conditional behavior for debug features
ENV LOG_LEVEL=DEBUG                    # Verbose logging for troubleshooting
ENV JUPYTER_ENABLE_LAB=yes             # Enable full Jupyter Lab interface

# ============================================================================
# SYSTEM DEPENDENCIES - Development tools and debugging utilities
# ============================================================================

WORKDIR /app

# Install system packages for development
RUN apt-get update && apt-get install -y --no-install-recommends \
    # Build tools for C extensions in Python packages
    build-essential \
    gcc \
    g++ \
    # Version control for Git operations
    git \
    # Network debugging utilities
    curl \
    wget \
    # Text processing and editing
    vim \
    nano \
    less \
    # Shell utilities and process management
    bash \
    bash-completion \
    # System monitoring tools for performance analysis
    htop \
    # Clean up package cache
    && rm -rf /var/lib/apt/lists/*

# ============================================================================
# PYTHON DEPENDENCIES - Full development stack
# ============================================================================

# Copy all project files for development environment
COPY pyproject.toml setup.py* setup.cfg* README.md ./
COPY src ./src
COPY tests ./tests
COPY configs ./configs
COPY scripts ./scripts
COPY docs ./docs
COPY notebooks ./notebooks
COPY benchmarks ./benchmarks
COPY Makefile .editorconfig .gitignore ./

# Upgrade pip and build tools
RUN pip install --no-cache-dir --upgrade \
    pip>=24.0 \
    setuptools>=77.0.0 \
    wheel>=0.43.0 \
    setuptools-scm>=7.1.0

# Install project with all optional dependencies for comprehensive development
# dev: linting, type checking, formatting tools
# test: pytest and testing plugins
# benchmarks: performance profiling tools
# notebooks: Jupyter and analysis tools
# deployment: docker, kubernetes tools
RUN pip install --no-cache-dir -e .[dev,test,benchmarks,notebooks,deployment]

# ============================================================================
# DEVELOPMENT TOOLS SETUP
# ============================================================================

# Install additional development utilities not in extras
RUN pip install --no-cache-dir \
    # Git workflow utilities
    gitpython>=3.1.0 \
    # REPL improvements
    ipython>=8.0.0 \
    # Debugging tools
    debugpy>=1.8.0 \
    # HTTP client for API testing
    httpie>=3.1.0 \
    # Database tools (if needed for data engineering)
    sqlite3-python>=1.0.0 2>/dev/null || true \
    # Profiling and performance analysis
    memory-profiler>=0.61.0 \
    line-profiler>=4.0.0

# ============================================================================
# VERIFICATION - Ensure all tools installed correctly
# ============================================================================

RUN python -c "import pytest; print(f'pytest: {pytest.__version__}')" && \
    mypy --version && \
    ruff --version && \
    echo "All development tools installed successfully"

# ============================================================================
# SHELL AND ENTRYPOINT
# ============================================================================

# Set bash as default shell for proper completion and history
SHELL ["/bin/bash", "-lc"]

# Enable bash history persistence across container runs
RUN echo 'export HISTFILE=/app/.bash_history' >> ~/.bashrc && \
    echo 'export HISTSIZE=10000' >> ~/.bashrc && \
    echo 'export HISTFILESIZE=20000' >> ~/.bashrc

# Default command: Interactive bash shell
# Can be overridden for specific tasks:
# - docker run --rm stochastic-transit-router:dev pytest tests/
# - docker run --rm stochastic-transit-router:dev mypy src/
# - docker run --rm stochastic-transit-router:dev ruff format src/
CMD ["bash"]

# =============================================================================
# DEVELOPMENT WORKFLOW
# =============================================================================
#
# Interactive Development Session:
# docker-compose -f docker/docker-compose.dev.yml run --rm dev
#
# Run Specific Tests:
# docker-compose -f docker/docker-compose.dev.yml run --rm dev pytest tests/unit -v
#
# Type Checking:
# docker-compose -f docker/docker-compose.dev.yml run --rm dev mypy src/ --strict
#
# Code Formatting:
# docker-compose -f docker/docker-compose.dev.yml run --rm dev ruff format src/
# docker-compose -f docker/docker-compose.dev.yml run --rm dev ruff check --fix src/
#
# Benchmarking:
# docker-compose -f docker/docker-compose.dev.yml run --rm dev pytest --benchmark-only tests/benchmarks/
#
# Jupyter Notebook:
# docker-compose -f docker/docker-compose.dev.yml run --rm -p 8888:8888 dev jupyter lab --ip=0.0.0.0
#
# Debugging with debugpy (VSCode/PyCharm):
# Add to code: import debugpy; debugpy.listen(("0.0.0.0", 5678)); debugpy.wait_for_client()
# docker run -it -v $(pwd):/app -p 5678:5678 stochastic-transit-router:dev python -m debugpy.adapter --log-dir /tmp -- -m pytest tests/
#
# Volume Mounting for Live Code Changes:
# All source code is mounted as a volume in docker-compose.dev.yml
# Changes to src/ appear immediately in container (ideal for TDD)
#
# Bash History Preservation:
# Bash history is saved to /app/.bash_history for persistence
#
# =============================================================================
