max_line_length = 100

# ============================================================================
# BINARY AND COMPRESSED FILES (NO FORMATTING)
# ============================================================================

[*.{pkl,pickle,parquet,arrow,msgpack}]
description = Binary data files
insert_final_newline = false
trim_trailing_whitespace = false

[*.{gz,zip,tar,tar.gz}]
description = Compressed data files
insert_final_newline = false
trim_trailing_whitespace = false

# ============================================================================
# SPECIAL PROJECT FILES
# ============================================================================

[{LICENSE,AUTHORS,CHANGELOG,SECURITY}]
description = Special project files
insert_final_newline = true
trim_trailing_whitespace = true
charset = utf-8

# ============================================================================
# CONFIGURATION NOTES
# ============================================================================

# This EditorConfig ensures:
# ✓ Consistent indentation across all editors
# ✓ Consistent line endings (LF on all platforms)
# ✓ Proper UTF-8 encoding throughout
# ✓ No trailing whitespace (cleaner diffs)
# ✓ Final newline in all text files
# ✓ Language-specific conventions followed
# ✓ Compliance with Python PEP 8, YAML standards

# Required extensions:
# - VS Code: "EditorConfig for VS Code" extension
# - PyCharm: Built-in support
# - Vim: editorconfig plugin
# - Emacs: editorconfig package

# Last Updated: 2026-04-05
# Maintained by: Zakir Bayramov, Gustav Olaf Yunus Laitinen-Lundström Fredriksson-Imanov
